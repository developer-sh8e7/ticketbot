# Opus Solutions Web — Vercel environment variables
# Add these in Vercel Project → Settings → Environment Variables.

# Public site URL. After adding the domain, use the final domain.
APP_URL=https://opussolutions.xyz

# Supabase (server-side only)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Encryption/session secrets
# Generate 32-byte base64 values with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=
TOKEN_ENCRYPTION_KEY=
SESSION_SECRET=
JWT_SECRET=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://opussolutions.xyz/api/auth/discord/callback
# Bot token used server-side only to DM project notifications to store owner 1397364822152315052.
OPUS_CONTROL_BOT_TOKEN=

# PayPal checkout
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Optional manager sync webhook (leave empty unless your running bot manager exposes a compatible sync endpoint)
MANAGER_SYNC_URL=
MANAGER_SYNC_SECRET=
TRIAL_MANAGER_ID=

# Admin/owner access
OWNER_DISCORD_ID=
STORE_GUILD_ID=
DEFAULT_PURCHASE_GUILD_ID=
ADMIN_DISCORD_IDS=

# Discord webhooks (optional but recommended)
DISCORD_WEBHOOK_LOGS=
DISCORD_BUY_WEB=

# Opi mascot chat (optional; if NVIDIA is busy/missing, Opi shows a friendly fallback)
NVIDIA_API_KEY=

# Optional overrides
TICKET_PRICE_USD=
LOG_LEVEL=info
