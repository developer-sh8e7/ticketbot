{
  "version": 2,
  "builds": [
    {
      "src": "src/web/server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "src/web/public/index.html"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/web/server.ts"
    }
  ]
}
