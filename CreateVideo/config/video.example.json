{
  "_readme": "Every step is defined here. Change the sequence/captions/urls without touching code. Copy this file to video.json.",

  "obs": {
    "host": "localhost",
    "port": 4455,
    "password": "YOUR_OBS_WEBSOCKET_PASSWORD",
    "scene": "Marketing"
  },

  "windows": {
    "browser_source_name": "Browser Capture",
    "browser_title_hint": "Chrome",
    "discord_source_name": "Discord Capture",
    "discord_title_hint": "Discord"
  },

  "browser": {
    "enabled": true,
    "channel": "chrome",
    "headless": false,
    "wait_until": "load",
    "nav_timeout_ms": 30000,
    "action_timeout_ms": 15000
  },

  "hide_taskbar": true,
  "pre_record_wait": 1.5,
  "post_record_wait": 1.5,
  "output_basename": "opus_marketing",

  "initial_sources": { "show": "Browser Capture", "hide": "Discord Capture" },

  "caption": {
    "window_title": "OpusCaption",
    "corner": "bottom-right",
    "margin": 48,
    "font": "Segoe UI",
    "font_size": 30,
    "text_color": "#ffffff",
    "box_color": "#111214",
    "border_color": "#2b2d31",
    "box_alpha": 0.92,
    "max_width": 620,
    "pad_x": 26,
    "pad_y": 16,
    "rtl": false
  },

  "steps": [
    {
      "name": "intro",
      "caption": "Opus Solutions - Discord bots by subscription",
      "action": { "type": "browser_goto", "url": "https://opussolutions.xyz/" },
      "wait": 5
    },
    {
      "name": "pricing",
      "caption": "Browse the plans and pricing",
      "action": { "type": "browser_goto", "url": "https://opussolutions.xyz/pricing" },
      "wait": 5
    },
    {
      "name": "scroll-pricing",
      "caption": "Pick the right product for your server",
      "action": { "type": "browser_scroll", "pixels": 700 },
      "wait": 4
    },
    {
      "name": "commands",
      "caption": "Ready-made, clear commands",
      "action": { "type": "browser_goto", "url": "https://opussolutions.xyz/commands" },
      "wait": 5
    },
    {
      "name": "switch-to-discord",
      "caption": "Support server on Discord",
      "action": {
        "type": "obs_switch",
        "show": "Discord Capture",
        "hide": "Browser Capture",
        "focus_window_contains": "Discord"
      },
      "wait": 5
    },
    {
      "name": "discord-tour",
      "caption": "Active community and live support",
      "action": { "type": "sleep", "seconds": 4 },
      "wait": 1
    },
    {
      "name": "back-to-site",
      "caption": "Get started - opussolutions.xyz",
      "action": {
        "type": "obs_switch",
        "show": "Browser Capture",
        "hide": "Discord Capture",
        "focus_window_contains": "Chrome"
      },
      "wait": 5
    }
  ]
}
