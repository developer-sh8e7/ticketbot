# ─────────────────────────────────────────────────────────────
# Opus Solutions — متغيرات البيئة (انسخه إلى .env واملأ القيم)
# ─────────────────────────────────────────────────────────────

# Supabase (مشترك بين كل الحزم — يستخدم Service Role Key على الخادم فقط)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# مفتاح تشفير التوكنات (Fernet-compatible). كل توكنات البوتات تُخزَّن مشفّرة.
# ولّد مفتاحاً قوياً واحفظه بأمان — فقدانه يعني فقدان القدرة على تشغيل أي بوت.
TOKEN_ENCRYPTION_KEY=

# ─── Orchestrator (طبقة التحكم) ───
# توكن بوت التحكم الرئيسي (Opus Control Bot) — يستقبل أوامر الإدارة والإشعارات
OPUS_CONTROL_BOT_TOKEN=
# آيدي مسؤول النظام
TRIAL_MANAGER_ID=1029665419788832800
# قناة إشعارات الاشتراكات/التجارب
OPUS_NOTIFY_CHANNEL_ID=1482267609062703104
# منفذ خادم الويب hook (يستقبل إشعار الدفع)
WEB_PORT=8787
# سر مشترك بين الموقع/الـ webhook والأوركستريتر (التحقق من المصدر)
MANAGER_SYNC_SECRET=

# ─── PayPal (تفعيل تلقائي بعد الدفع) ───
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# ─── Discord OAuth (ربط الحساب الإجباري قبل الشراء) ───
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://your-site.com/api/auth/callback

# ─── AI (متاح في النسخة المدفوعة فقط — لبوت التكتات) ───
AI_PROVIDER=openai
AI_BASE_URL=https://opencode.ai/zen/v1
AI_MODEL=deepseek-v4-flash-free
GEMINI_API_KEY=

# ─── أوبي (Opi) — mascot الموقع التفاعلي ───
# مفتاح NVIDIA API (build.nvidia.com) — يشغّل ردود أوبي عبر deepseek-v4-pro
NVIDIA_API_KEY=

# مستوى السجلّات
LOG_LEVEL=info
